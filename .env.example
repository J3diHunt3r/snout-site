# Copy to .env.local — no commas at end of lines, no quotes unless value has spaces

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firestore path: collection/document (default reads stats/public).
# Or set collection + doc id separately:
# VITE_FIREBASE_STATS_COLLECTION=stats
# VITE_FIREBASE_STATS_DOC_ID=public
VITE_FIREBASE_STATS_DOC_PATH=stats/public

# Only if you use a named Firestore database (not "(default)"):
# VITE_FIREBASE_FIRESTORE_DATABASE_ID=

VITE_FIREBASE_STATS_MODE=document
